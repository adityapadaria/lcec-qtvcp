           <widget class="StatusSlider" name="statusslider_14">
            <property name="styleSheet">
             <string notr="true">QSlider {
    padding: 5px;
    height: 60px;
}

QSlider::groove:horizontal {
    subcontrol-origin: content;
    background: white;

    /* the groove expands to the size of the slider by default.
    by giving it a height, it has a fixed size */
    height: 35px;
}

QSlider::handle:horizontal {
    background-color: black;
    width: 50px;
    border-radius: 15px;

    /* handle is placed by default on the contents rect of the groove.
    Expand outside the groove */
    margin: -15px 0;
}

QSlider::sub-page:horizontal {
    background: rgb(153, 193, 241);
    margin: 12px;
    border-radius: 50px;
}

QSlider::add-page:horizontal {
    background: darkgrey;
    margin: 14px;
    border-radius: 50px;
}</string>
            </property>
